# ==========================================
# STAGE 1: Builder (Development)
# ==========================================
FROM node:20-alpine AS builder

WORKDIR /app

# Copiar package files
COPY package*.json ./

# Instalar dependencias
RUN npm install

# Copiar schema de Prisma ANTES de generar
COPY prisma ./prisma

# Generar Prisma Client
RUN npx prisma generate

# Copiar el resto del código
COPY . .

# Compilar TypeScript
RUN npm run build

# ==========================================
# STAGE 2: Production (si la necesitas)
# ==========================================
FROM node:20-alpine AS production

WORKDIR /app

# Copiar package files
COPY --from=builder /app/package*.json ./

# Copiar schema de Prisma
COPY --from=builder /app/prisma ./prisma

# Instalar solo dependencias de producción
RUN npm install --omit=dev

# Generar Prisma Client en producción
RUN npx prisma generate

# Copiar código compilado
COPY --from=builder /app/dist ./dist

EXPOSE 3000

# Ejecutar migraciones y arrancar
CMD ["sh", "-c", "npx prisma migrate deploy && node dist/index.js"]

# ==========================================
# STAGE 3: Development (para docker-compose)
# ==========================================
FROM node:20-alpine AS development

WORKDIR /app

# Copiar package files
COPY package*.json ./

# Instalar todas las dependencias
RUN npm install

# Copiar schema de Prisma
COPY prisma ./prisma

# Generar Prisma Client
RUN npx prisma generate

# El código se monta como volumen en docker-compose
# No necesitamos COPY . . aquí

EXPOSE 3000

# Este comando se sobreescribe en docker-compose.yml
CMD ["npm", "run", "dev"]