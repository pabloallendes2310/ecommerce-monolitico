# 1. Usamos una imagen ligera de Node.js
FROM node:20-alpine AS builder

# 2. Creamos el directorio de trabajo
WORKDIR /app

# 3. Copiamos los archivos de dependencias primero 
# (Esto ayuda a aprovechar el cache de Docker)
COPY package*.json ./

# 4. Instalamos todas las dependencias
RUN npm install

# 5. Copiamos el resto del código del proyecto
COPY . .

# 6. Compilamos el código (ejecuta 'tsc' via tu script de build)
RUN npm run build
# 7. Iniciamos una nueva etapa limpia
FROM node:20-alpine AS runner

WORKDIR /app

# 8. Copiamos solo los archivos necesarios de la etapa 'builder'
COPY --from=builder /app/package*.json ./
COPY --from=builder /app/dist ./dist

# 9. Instalamos SOLO dependencias de producción
RUN npm install --omit=dev

# 10. Exponemos el puerto y ejecutamos la app
EXPOSE 3000
CMD ["node", "dist/app.js"]