# ==========================================
# STAGE 1: Builder (Development)
# ==========================================
FROM node:20-alpine AS builder

WORKDIR /app

# Copiar package files e instalar dependencias
COPY package*.json ./
# Instalar todas las dependencias (incluyendo dev)
RUN npm install

# Copiar schema de Prisma
COPY prisma ./prisma
# Copiar configuración de Prisma
COPY prisma.config.ts ./

# Generar Prisma Client (Bypass para Build Time)
RUN DATABASE_URL="postgresql://dummy:dummy@localhost/dummy" npx prisma generate

# Copiar código fuente y compilar TypeScript
COPY . .
RUN npm run build

# ==========================================
# STAGE 2: Production
# ==========================================
FROM node:20-alpine AS production

WORKDIR /app

# Copiar dependencias y artefactos del builder
COPY --from=builder /app/package*.json ./
# Copiar schema de Prisma
COPY --from=builder /app/prisma ./prisma
# Copiar configuración de Prisma
COPY --from=builder /app/prisma.config.ts ./

# Instalar solo dependencias de producción
RUN npm install --omit=dev

# Copiar el código ya compilado de TypeScript
COPY --from=builder /app/dist ./dist

# Generar Prisma Client nativo para el entorno de producción
RUN DATABASE_URL="postgresql://dummy:dummy@localhost/dummy" npx prisma generate

# ENSAMBLAJE DE ARTEFACTOS: Mover la carpeta generada para satisfacer la ruta de Node.js
RUN cp -r /app/generated /app/dist/

EXPOSE 3000

# Ejecutar migraciones y arrancar el servidor
CMD ["sh", "-c", "npx prisma migrate deploy && node dist/src/app.js"]

# ==========================================
# STAGE 3: Development (para docker-compose)
# ==========================================
FROM node:20-alpine AS development

WORKDIR /app

# Copiar package files
COPY package*.json ./
# Instalar todas las dependencias
RUN npm install

# Copiar schema de Prisma
COPY prisma ./prisma

# Generar Prisma Client (MODIFICADO: Bypass para Build Time)
RUN DATABASE_URL="postgresql://dummy:dummy@localhost/dummy" npx prisma generate

# El código se monta como volumen en docker-compose
# No necesitamos COPY . . aquí
EXPOSE 3000

# Este comando se sobreescribe en docker-compose.yml
CMD ["npm", "run", "dev"]